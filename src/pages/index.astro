---
const base = import.meta.env.BASE_URL;
---
<html lang="ja">
<head>
    <meta charset="UTF-8" />
    <title>書式リポジトリ</title>
    <style>
        body { font-family: sans-serif; padding: 40px; background: #f5f5f5; }
        .container { max-width: 600px; margin: 0 auto; background: white; padding: 40px; border: 1px solid #ddd; }
        h1 { font-size: 20px; border-bottom: 1px solid #ddd; padding-bottom: 10px; }
        ul { list-style: none; padding: 0; }
        li { margin: 10px 0; }
        a { text-decoration: none; color: #0033cc; font-size: 16px; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="container">
        <h1>保存文書一覧</h1>
        <ul>
            <li><a href={`${base}/heritage-division`}>・ 遺産分割協議書</a></li>
            <li><a href={`${base}/touki-application`}>・ 登記申請書（所有権移転）</a></li>
            <li><a href={`${base}/inheritance-diagram`}>・ 相続関係説明図</a></li>
            <li><a href={`${base}/power-of-attorney`}>・ 委任状（所有権移転）</a></li>
        </ul>
    </div>
</body>
</html>